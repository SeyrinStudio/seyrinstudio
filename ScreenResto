<!doctype html>
<html lang="fr">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Restaurant Asiatique — Menu</title>
  <style>
    :root{--bg:#0f0b0d;--card:#171116;--card2:#22171d;--text:#f7f2e8;--muted:#c9b9aa;--red:#d11f2f;--gold:#d7b35a;--green:#4caf72;--line:rgba(255,255,255,.08)}
    *{box-sizing:border-box} body{margin:0;font-family:Inter,system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;background:radial-gradient(circle at top, #2b1518 0%, var(--bg) 45%);color:var(--text)}
    header{padding:28px 20px 12px;max-width:1200px;margin:0 auto}
    .brand{display:flex;align-items:center;gap:14px;margin-bottom:10px}
    .logo{width:48px;height:48px;border-radius:16px;background:linear-gradient(135deg,var(--red),var(--gold));display:grid;place-items:center;font-size:24px;box-shadow:0 10px 30px rgba(209,31,47,.35)}
    h1{margin:0;font-size:clamp(28px,4vw,48px);line-height:1.05}
    .subtitle{color:var(--muted);max-width:720px;margin:10px 0 0}
    .layout{max-width:1200px;margin:0 auto;padding:14px 20px 28px;display:grid;grid-template-columns:1.45fr .9fr;gap:18px;align-items:start}
    .menu-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:16px}
    .card,.cart{background:linear-gradient(180deg,var(--card),var(--card2));border:1px solid var(--line);border-radius:22px;box-shadow:0 18px 55px rgba(0,0,0,.25)}
    .menu-item{overflow:hidden}
    .hero{height:148px;background:linear-gradient(135deg,rgba(209,31,47,.35),rgba(215,179,90,.2)),url('https://images.unsplash.com/photo-1541542684-4f7a0b8d7d7f?auto=format&fit=crop&w=1200&q=80') center/cover}
    .hero2{background-image:linear-gradient(135deg,rgba(209,31,47,.35),rgba(215,179,90,.2)),url('https://images.unsplash.com/photo-1525755662778-989d0524087e?auto=format&fit=crop&w=1200&q=80')}
    .hero3{background-image:linear-gradient(135deg,rgba(209,31,47,.35),rgba(215,179,90,.2)),url('https://images.unsplash.com/photo-1512058564366-18510be2db19?auto=format&fit=crop&w=1200&q=80')}
    .hero4{background-image:linear-gradient(135deg,rgba(209,31,47,.35),rgba(215,179,90,.2)),url('https://images.unsplash.com/photo-1569718212165-3a8278d5f624?auto=format&fit=crop&w=1200&q=80')}
    .hero5{background-image:linear-gradient(135deg,rgba(209,31,47,.35),rgba(215,179,90,.2)),url('https://images.unsplash.com/photo-1553621042-f6e147245754?auto=format&fit=crop&w=1200&q=80')}
    .hero6{background-image:linear-gradient(135deg,rgba(209,31,47,.35),rgba(215,179,90,.2)),url('https://images.unsplash.com/photo-1625938145744-3dca3c4dcd0b?auto=format&fit=crop&w=1200&q=80')}
    .content{padding:16px}
    .topline{display:flex;justify-content:space-between;gap:12px;align-items:start}
    .title{font-size:20px;font-weight:700;margin:0 0 6px}
    .desc{margin:0;color:var(--muted);font-size:14px;line-height:1.5}
    .meta{display:flex;align-items:center;justify-content:space-between;margin-top:14px;gap:12px}
    .price{font-size:22px;font-weight:800;color:var(--gold)}
    .btn{border:0;border-radius:14px;padding:12px 14px;font-weight:700;cursor:pointer;transition:.2s ease}
    .btn-primary{background:linear-gradient(135deg,var(--red),#f04d46);color:#fff;box-shadow:0 8px 24px rgba(209,31,47,.3)}
    .btn-primary:hover{transform:translateY(-1px)}
    .btn-ghost{background:transparent;color:var(--text);border:1px solid var(--line)}
    .cart{position:sticky;top:18px;padding:18px;min-height:calc(100vh - 36px)}
    .cart h2,.modal h2{margin:0 0 12px}
    .cart-list{display:grid;gap:10px;margin:12px 0 16px}
    .cart-item{display:flex;justify-content:space-between;gap:10px;padding:12px;border:1px solid var(--line);border-radius:16px;background:rgba(255,255,255,.03)}
    .cart-item small{color:var(--muted)}
    .empty{color:var(--muted);border:1px dashed var(--line);padding:16px;border-radius:16px;text-align:center}
    .total{display:flex;justify-content:space-between;align-items:center;margin:10px 0 16px;font-size:18px}
    .total strong{color:var(--gold)}
    .badge{display:inline-flex;align-items:center;gap:8px;background:rgba(215,179,90,.12);border:1px solid rgba(215,179,90,.22);color:var(--gold);padding:8px 12px;border-radius:999px;font-size:13px}
    .modal-backdrop{position:fixed;inset:0;background:rgba(10,8,10,.72);backdrop-filter:blur(8px);display:none;align-items:center;justify-content:center;padding:18px;z-index:20}
    .modal-backdrop.open{display:flex}
    .modal{width:min(920px,100%);background:linear-gradient(180deg,#1f1418,#130d10);border:1px solid var(--line);border-radius:24px;overflow:hidden;box-shadow:0 30px 90px rgba(0,0,0,.5)}
    .modal-grid{display:grid;grid-template-columns:1fr 1fr;min-height:420px}
    .modal-media{background:linear-gradient(135deg,rgba(209,31,47,.35),rgba(215,179,90,.18));padding:24px;display:flex;align-items:center;justify-content:center}
    .plate{width:min(100%,360px);aspect-ratio:1;border-radius:30px;background:radial-gradient(circle at 30% 30%, #fff6 0, transparent 30%), linear-gradient(145deg,#f2d7a1,#9e6332 55%,#341d16);box-shadow:0 20px 70px rgba(0,0,0,.35);position:relative;overflow:hidden}
    .plate:before,.plate:after{content:'';position:absolute;border-radius:50%;background:rgba(255,255,255,.15)}
    .plate:before{width:120px;height:120px;right:22px;top:22px}.plate:after{width:70px;height:70px;left:28px;bottom:28px}
    .modal-body{padding:24px;display:flex;flex-direction:column;gap:14px}
    .detail-price{font-size:28px;font-weight:900;color:var(--gold)}
    .qty{display:flex;align-items:center;gap:10px}
    .qty button{width:42px;height:42px;border-radius:12px;border:1px solid var(--line);background:rgba(255,255,255,.04);color:var(--text);font-size:20px}
    .qty span{min-width:28px;text-align:center;font-size:18px;font-weight:700}
    .close{position:absolute;right:14px;top:14px;width:40px;height:40px;border-radius:12px;border:1px solid var(--line);background:rgba(255,255,255,.06);color:var(--text);font-size:18px}
    .toast{position:fixed;left:50%;bottom:18px;transform:translateX(-50%);background:#121212;color:#fff;padding:12px 16px;border-radius:999px;border:1px solid rgba(255,255,255,.08);opacity:0;pointer-events:none;transition:.25s;z-index:30}
    .toast.show{opacity:1;transform:translateX(-50%) translateY(-4px)}
    @media (max-width: 980px){.layout{grid-template-columns:1fr}.cart{position:relative;top:0;min-height:auto}.menu-grid{grid-template-columns:1fr}.modal-grid{grid-template-columns:1fr}.modal-media{min-height:240px}}
  </style>
</head>
<body>
  <header>
    <div class="brand">
      <div class="logo">龍</div>
      <div>
        <h1>Maison du Dragon</h1>
        <div class="badge">Cuisine asiatique — commande en ligne</div>
      </div>
    </div>
    <p class="subtitle">Sélectionne un menu pour l’ajouter au panier. La fiche produit s’ouvre en parallèle pour ajuster la quantité et valider ta sélection.</p>
  </header>

  <main class="layout">
    <section>
      <div class="menu-grid" id="menuGrid"></div>
    </section>

    <aside class="cart">
      <h2>Panier</h2>
      <div id="cartList" class="cart-list"></div>
      <div class="total"><span>Total</span><strong id="cartTotal">0 €</strong></div>
      <button class="btn btn-primary" style="width:100%">Commander</button>
    </aside>
  </main>

  <div class="modal-backdrop" id="modalBackdrop" aria-hidden="true">
    <div class="modal" role="dialog" aria-modal="true">
      <button class="close" id="closeModal">✕</button>
      <div class="modal-grid">
        <div class="modal-media"><div class="plate"></div></div>
        <div class="modal-body">
          <div class="badge" id="modalCategory">Menu</div>
          <h2 id="modalTitle">Titre</h2>
          <p id="modalDesc" class="desc"></p>
          <div class="detail-price" id="modalPrice">0 €</div>
          <div class="qty">
            <button id="minusQty">−</button><span id="qtyValue">1</span><button id="plusQty">+</button>
          </div>
          <button class="btn btn-primary" id="addToCart">Ajouter au panier</button>
          <button class="btn btn-ghost" id="continue">Continuer les achats</button>
        </div>
      </div>
    </div>
  </div>

  <div class="toast" id="toast">Ajouté au panier</div>

  <script>
    const menus = [
      {id:1,name:'Ramen Shoyu',cat:'Noodle Bowl',price:14.9,desc:'Bouillon soja, nouilles, œuf mariné, champignons, pak choï.'},
      {id:2,name:'Bowl Teriyaki',cat:'Rice Bowl',price:13.5,desc:'Poulet laqué, riz jasmin, sésame, légumes croquants.'},
      {id:3,name:'Sushi Mix',cat:'Sushi',price:18.9,desc:'12 pièces assorties : maki, nigiri, california et gingembre.'},
      {id:4,name:'Pad Thai',cat:'Wok',price:15.2,desc:'Nouilles sautées, cacahuètes, citron vert, crevettes ou tofu.'},
      {id:5,name:'Curry Rouge',cat:'Curry',price:16.4,desc:'Lait de coco, basilic thaï, légumes, riz parfumé.'},
      {id:6,name:'Bao Duo',cat:'Street Food',price:12.8,desc:'Deux bao buns vapeur, porc braisé, pickles, coriandre.'}
    ];

    const cart = new Map();
    const menuGrid = document.getElementById('menuGrid');
    const cartList = document.getElementById('cartList');
    const cartTotal = document.getElementById('cartTotal');
    const backdrop = document.getElementById('modalBackdrop');
    const toast = document.getElementById('toast');
    const modalTitle = document.getElementById('modalTitle');
    const modalDesc = document.getElementById('modalDesc');
    const modalPrice = document.getElementById('modalPrice');
    const modalCategory = document.getElementById('modalCategory');
    const qtyValue = document.getElementById('qtyValue');
    let currentItem = null, qty = 1;

    function eur(v){ return new Intl.NumberFormat('fr-FR',{style:'currency',currency:'EUR'}).format(v); }
    function showToast(msg){ toast.textContent = msg; toast.classList.add('show'); setTimeout(()=>toast.classList.remove('show'), 1500); }
    function openModal(item){ currentItem = item; qty = 1; qtyValue.textContent = qty; modalTitle.textContent = item.name; modalDesc.textContent = item.desc; modalPrice.textContent = eur(item.price); modalCategory.textContent = item.cat; backdrop.classList.add('open'); backdrop.setAttribute('aria-hidden','false'); }
    function closeModal(){ backdrop.classList.remove('open'); backdrop.setAttribute('aria-hidden','true'); }
    function renderCart(){
      cartList.innerHTML = '';
      let total = 0;
      if(cart.size === 0){ cartList.innerHTML = '<div class="empty">Ton panier est vide.</div>'; }
      cart.forEach((v,k)=>{ total += v.price*v.qty; const el = document.createElement('div'); el.className='cart-item'; el.innerHTML = `<div><strong>${v.name}</strong><br><small>x${v.qty} · ${eur(v.price)}</small></div><div><strong>${eur(v.price*v.qty)}</strong></div>`; cartList.appendChild(el); });
      cartTotal.textContent = eur(total);
    }
    function renderMenus(){
      menuGrid.innerHTML = menus.map((m,i)=>`<article class="card menu-item"><div class="hero ${i===1?'hero2':''} ${i===2?'hero3':''} ${i===3?'hero4':''} ${i===4?'hero5':''} ${i===5?'hero6':''}"></div><div class="content"><div class="topline"><div><div class="badge">${m.cat}</div><h3 class="title">${m.name}</h3></div></div><p class="desc">${m.desc}</p><div class="meta"><div class="price">${eur(m.price)}</div><button class="btn btn-primary" data-id="${m.id}">Sélectionner</button></div></div></article>`).join('');
      document.querySelectorAll('[data-id]').forEach(btn=>btn.addEventListener('click',()=>openModal(menus.find(m=>m.id==btn.dataset.id))));
    }
    document.getElementById('minusQty').onclick = ()=>{ qty = Math.max(1, qty-1); qtyValue.textContent = qty; };
    document.getElementById('plusQty').onclick = ()=>{ qty += 1; qtyValue.textContent = qty; };
    document.getElementById('addToCart').onclick = ()=>{ const item = cart.get(currentItem.id) || {...currentItem, qty:0}; item.qty += qty; cart.set(currentItem.id,item); renderCart(); showToast(`${currentItem.name} ajouté au panier`); closeModal(); };
    document.getElementById('closeModal').onclick = closeModal;
    document.getElementById('continue').onclick = closeModal;
    backdrop.addEventListener('click', e => { if(e.target === backdrop) closeModal(); });
    renderMenus(); renderCart();
  </script>
</body>
</html>
